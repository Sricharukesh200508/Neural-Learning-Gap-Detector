{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watch": ["backend/**"],
    "aptPkgs": [
      "libgl1-mesa-glx",
      "libglib2.0-0",
      "libavcodec-dev",
      "libavformat-dev",
      "libswscale-dev"
    ]
  },
  "deploy": {
    "startCommand": "cd backend && pip install -r requirements.txt && uvicorn main:app --host 0.0.0.0 --port $PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
